{
  "name": "minnaldb-electron-example",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Electron + React task manager using minnaldb from npm",
  "main": "out/main/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist": "electron-vite build && electron-builder --config electron-builder.yml",
    "dist:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "dist:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "dist:linux": "electron-vite build && electron-builder --linux --config electron-builder.yml"
  },
  "dependencies": {
    "minnaldb": "^0.0.2",
    "minnaldb-electron": "^0.0.2",
    "minnaldb-react": "^0.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
